# File containing TikTok Shop category URLs, one URL per line.
URLS_FILE="data/category-urls.txt"

# Number of products to discover per category URL.
# Example: 3 category URLs * 25 = up to 75 discovered products.
PRODUCT_LIMIT_PER_URL=25

# Set to false if you want to keep current DB data.
RESET_DB=true

# Intermediate file generated by the product-list crawler.
OUTPUT_FILE="data/discovered-product-urls.txt"

# Product-list crawler options.
SOURCE="tiktok"
FETCHER="dynamic"
EXPAND_CATEGORY_PAGES=true
MAX_CATEGORY_PAGES=8
SCROLL_ROUNDS=2
READ_MORE_CLICKS=1
SCROLL_WAIT_MS=800
LIST_DELAY=0
LIST_CACHE_TTL=0

# Product-detail crawler options.
BATCH_DELAY=1
DETAIL_DELAY=0
DETAIL_CACHE_TTL=43200
MAX_REVIEWS=3
