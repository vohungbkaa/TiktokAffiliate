generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id               String   @id
  name             String
  productUrl       String   @unique
  externalId       String?  @unique
  imageUrl         String?
  category         String?
  shopName         String?
  shopUrl          String?
  price            Decimal?
  currency         String   @default("USD")
  commissionRate   Decimal?
  commissionAmount Decimal?
  soldCount        Int      @default(0)
  rating           Float?
  reviewCount      Int      @default(0)
  badReviewCount   Int      @default(0)
  shopRating       Float?
  voucherInfo      String?
  shippingNote     String?
  rawSource        String?
  lastCrawledAt    DateTime?
  status           String   @default("new")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  reviews      ProductReview[]
  snapshots    RawCrawlSnapshot[]

  @@index([category])
  @@index([rating])
  @@index([commissionRate])
  @@index([soldCount])
}

model ProductReview {
  id         String   @id @default(cuid())
  productId  String
  author     String?
  rating     Float?
  content    String
  isBad      Boolean  @default(false)
  hasImage   Boolean  @default(false)
  hasVideo   Boolean  @default(false)
  source     String?
  reviewedAt DateTime?
  capturedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isBad])
}

model CrawlJob {
  id          String    @id @default(cuid())
  source      String
  jobType     String    @default("product_detail")
  status      String    @default("queued")
  targetUrl   String?
  attemptCount Int      @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  finishedAt  DateTime?
  error       String?
  errorMessage String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  snapshots RawCrawlSnapshot[]

  @@index([status])
  @@index([source])
  @@index([jobType])
  @@index([targetUrl])
}

model CrawlTarget {
  id                  String    @id @default(cuid())
  url                 String    @unique
  label               String?
  source              String    @default("tiktok")
  maxItems            Int       @default(25)
  fetcher             String    @default("dynamic")
  expandCategoryPages Boolean   @default(true)
  maxCategoryPages    Int       @default(8)
  scrollRounds        Int       @default(2)
  readMoreClicks      Int       @default(1)
  scrollWaitMs        Int       @default(800)
  status              String    @default("pending")
  discoveredCount     Int       @default(0)
  crawledCount        Int       @default(0)
  lastError           String?
  lastStartedAt       DateTime?
  lastFinishedAt      DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([status])
  @@index([source])
}

model RawCrawlSnapshot {
  id        String   @id @default(cuid())
  productId String?
  crawlJobId String?
  source    String?
  sourceUrl String
  targetUrl String?
  contentHash String?
  payload   Json
  rawPayload Json?
  capturedAt DateTime @default(now())
  createdAt DateTime @default(now())

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  crawlJob CrawlJob? @relation(fields: [crawlJobId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([crawlJobId])
}
